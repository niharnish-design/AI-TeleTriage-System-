rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {uid}
    // Fields:
    //   - uid: string (required)
    //   - displayName: string (optional)
    //   - email: string (required)
    //   - role: string (required, 'user'|'admin')
    //   - createdAt: timestamp (required)
    //
    // Collection: sessions
    // Document ID: {sessionId}
    // Fields:
    //   - userId: string (required)
    //   - status: string (required, 'active'|'completed')
    //   - createdAt: timestamp (required)
    //   - lastUpdated: timestamp (required)
    //   - summary: string (optional)
    //   - severity: string (optional, 'low'|'medium'|'high'|'emergency')
    //
    // Collection: sessions/{sessionId}/messages
    // Document ID: {messageId}
    // Fields:
    //   - sessionId: string (required)
    //   - sender: string (required, 'user'|'ai')
    //   - text: string (required)
    //   - type: string (required, 'text'|'image'|'voice')
    //   - imageUrl: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isSessionOwner(sessionId) {
      return isAuthenticated() && get(/databases/$(database)/documents/sessions/$(sessionId)).data.userId == request.auth.uid;
    }

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.uid == request.auth.uid &&
             data.role in ['user', 'admin'] &&
             data.email is string;
    }

    function isValidSession(data) {
      return data.keys().hasAll(['userId', 'status', 'createdAt', 'lastUpdated']) &&
             data.userId == request.auth.uid &&
             data.status in ['active', 'completed'];
    }

    function isValidMessage(data, sessionId) {
      return data.keys().hasAll(['sessionId', 'sender', 'text', 'type', 'createdAt']) &&
             data.sessionId == sessionId &&
             data.sender in ['user', 'ai'] &&
             data.type in ['text', 'image', 'voice'];
    }

    // Rules
    match /users/{uid} {
      allow read: if isOwner(uid);
      allow create: if isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == 'user';
      allow update: if isOwner(uid) && isValidUser(request.resource.data) && request.resource.data.role == resource.data.role;
    }

    match /sessions/{sessionId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && isValidSession(request.resource.data);
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidSession(request.resource.data);
      
      match /messages/{messageId} {
        allow read: if isSessionOwner(sessionId);
        allow create: if isSessionOwner(sessionId) && isValidMessage(request.resource.data, sessionId);
      }
    }
  }
}
